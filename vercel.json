{
  "version": 2,
  "routes": [
    { "src": "/api/forms/(.+)", "dest": "/api/forms" },
    { "src": "/api/analytics/(.+)", "dest": "/api/analytics" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/", "dest": "/builder.html" },
    { "src": "/(.*\\.html)", "dest": "/$1" }
  ],
  "functions": {
    "api/submit.js":    { "memory": 256, "maxDuration": 15 },
    "api/forms.js":     { "memory": 128, "maxDuration": 10 },
    "api/analytics.js": { "memory": 128, "maxDuration": 10 },
    "api/health.js":    { "memory": 128, "maxDuration": 5  }
  }
}